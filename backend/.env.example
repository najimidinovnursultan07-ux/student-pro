# --- Local development (copy to backend/.env) ---
# Ключ: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
# Запасные модели через запятую (используются при 429/перегрузке)
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-1.5-flash-8b
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Render (Dashboard → Environment) ---
# GEMINI_API_KEY=<ваш ключ Google AI Studio>
# GEMINI_MODEL=gemini-2.5-flash
# DJANGO_SECRET_KEY=<случайная строка 50+ символов>
# DEBUG=False
# ALLOWED_HOSTS=your-service.onrender.com
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
